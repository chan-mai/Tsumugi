{
  "name": "tsumugi-root",
  "private": true,
  "type": "module",
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run typecheck && npm run build -w tsumugi && vitest run",
    "test:unit": "vitest run --project unit",
    "test:workers": "npm run build -w tsumugi && vitest run --project workers",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.6",
    "prettier": "^3.6.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10",
    "wrangler": "^4.112.0"
  }
}
